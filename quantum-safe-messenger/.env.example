# ──────────────────────────────────────────
# QuantumSafe Messenger — Environment Variables
# Copy this file to .env.local (frontend) and server/.env (backend)
# NEVER commit .env files to git
# ──────────────────────────────────────────

# ── FRONTEND (.env.local) ──
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_CONTRACT_ADDRESS=           # Polygon contract address (Phase 4)

# ── BACKEND (server/.env) ──
PORT=3001
NODE_ENV=development

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database — matches Docker service name
DATABASE_URL=postgresql://postgres:your_db_password@localhost:5432/quantum_safe_messenger
DB_PASSWORD=your_db_password_here

# Redis — matches Docker service name
REDIS_URL=redis://:your_redis_password@localhost:6379
REDIS_PASSWORD=your_redis_password_here

# Bcrypt
BCRYPT_ROUNDS=12

# Queue TTLs
REDIS_QUEUE_TTL_SECONDS=172800          # 48 hours (default, in-memory)
PG_QUEUE_TTL_DAYS=7                     # 7 days (opt-in reliable mode)

# Blockchain (Phase 4 — leave empty for now)
BLOCKCHAIN_PRIVATE_KEY=
POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com

# Push Notifications (Phase 5 — leave empty for now)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# CORS
CORS_ORIGIN=http://localhost:3000
